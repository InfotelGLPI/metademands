<div class="card mt-2">
    <div class="card-header">
        <h5 class="card-title">{{ __('Specific parameters', 'metademands') }}</h5>
    </div>
    <div class="card-body">
        <div class="row g-2 align-items-center mb-2">
            <label class="col-sm-3 col-form-label">{{ __('Day greater or equal to now', 'metademands') }}</label>
            <div class="col-sm-3">{{ use_future_date_html|raw }}</div>
            <label class="col-sm-3 col-form-label">{{ __('Define the default date', 'metademands') }}</label>
            <div class="col-sm-3">{{ use_date_now_html|raw }}</div>
        </div>
        <div class="row g-2 align-items-center mb-2">
            <label
                class="col-sm-3 col-form-label">{{ __('Additional number day to the default date', 'metademands') }}</label>
            <div class="col-sm-3">{{ additional_number_day_html|raw }}</div>
        </div>
    </div>
</div>
