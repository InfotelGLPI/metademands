{% import 'components/form/basic_inputs_macros.html.twig' as inputs %}

{% set modal_id = 'modal_tickettask_' ~ tasks_id %}

<div class="modal fade" id="{{ modal_id }}" tabindex="-1" aria-modal="true" role="dialog">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    {{ is_new ? __('Add a ticket task', 'metademands') : __('Edit ticket task', 'metademands') }}
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ __('Close') }}"></button>
            </div>

            <div class="modal-body" style="overflow-y:auto; max-height:75vh;">
                <form name="form_ticket" method="post"
                      action="{{ form_action }}?_in_modal=1&id={{ field_id }}"
                      enctype="multipart/form-data">
                    {{ inputs.hidden('_glpi_csrf_token', csrf_token()) }}
                    {{ inputs.hidden('plugin_metademands_tasks_id', tasks_id) }}
                    {% if tickettemplates_id > 0 %}
                        {{ inputs.hidden('_tickettemplates_id', tickettemplates_id) }}
                    {% endif %}
                    {{ inputs.hidden('type', type) }}
                    {{ inputs.hidden('entities_id', entities_id) }}
                    {% if not is_new %}
                        {{ inputs.hidden('id', field_id) }}
                    {% endif %}

                    {{ form_content_html|raw }}

                    <div class="d-flex justify-content-end gap-2 mt-3">
                        {% if canedit %}
                            <button type="submit" name="{{ is_new ? 'add' : 'update' }}" value="1"
                                    class="btn btn-primary">
                                <i class="ti ti-device-floppy"></i>
                                <span>{{ is_new ? _x('button', 'Add') : _x('button', 'Save') }}</span>
                            </button>
                        {% endif %}
                        {% if can_delete %}
                            <button type="submit" name="delete" value="1"
                                    class="btn btn-danger"
                                    onclick="return confirm('{{ __('Are you sure you want to delete this item?')|e('js') }}');">
                                <i class="ti ti-trash"></i>
                                <span>{{ _x('button', 'Delete permanently'), }}</span>
                            </button>
                        {% endif %}
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    bootstrap.Modal.getOrCreateInstance(document.getElementById('{{ modal_id }}')).show();
</script>
