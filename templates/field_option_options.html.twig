{% if not allowed %}
    <div class="alert alert-warning">
        {{ __('No options are allowed for this field type', 'metademands') }}
    </div>
{% elseif link_to_user %}
    <div class="alert alert-warning">
        {{ __("Options aren't available for a field whose value is linked to a user field", 'metademands') }}
    </div>
{% else %}

    {{ ajax_html|raw }}

    {{ options_list_html|raw }}

{% endif %}
