{% import 'components/form/basic_inputs_macros.html.twig' as inputs %}

{% do call('Html::requireJs', ['tinymce']) %}

{{ inputs.hidden('itilcategories_id', 0) }}
{{ inputs.hidden('formatastable', 1) }}
{{ inputs.hidden('mailtask_id', mailtask_id) }}

<div class="row mb-3">
    <label class="col-4 col-form-label fw-bold">{{ __('Use block', 'metademands') }}</label>
    <div class="col-8">{{ use_block_html|raw }}</div>
</div>

<div class="row mb-3">
    <label class="col-4 col-form-label fw-bold">{{ __('Block to use', 'metademands') }}</label>
    <div class="col-8">{{ block_use_html|raw }}</div>
</div>

<hr class="my-3">

<div class="row mb-3">
    <label class="col-4 col-form-label fw-bold">
        {{ __('Actors', 'metademands') }} — {{ __('Recipient') }} ({{ __('User') }})
    </label>
    <div class="col-8">{{ user_recipient_html|raw }}</div>
</div>

<div class="row mb-3">
    <label class="col-4 col-form-label fw-bold">
        {{ __('Actors', 'metademands') }} — {{ __('Recipient') }} ({{ __('Group') }})
    </label>
    <div class="col-8">{{ group_recipient_html|raw }}</div>
</div>

<hr class="my-3">

<div class="row mb-3">
    <label class="col-4 col-form-label fw-bold">{{ __('Title') }}</label>
    <div class="col-8">
        <input type="text" class="form-control" name="name" value="{{ name }}">
    </div>
</div>

<div class="row mb-3">
    <label class="col-4 col-form-label fw-bold">{{ __('Description') }}</label>
    <div class="col-8">
        {% do call('Html::textarea', [{'name': 'content', 'value': content,
            'enable_richtext': true, 'enable_fileupload': false,
            'enable_images': false, 'rows': 3}]) %}
    </div>
</div>
