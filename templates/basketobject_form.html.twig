{% import 'components/form/basic_inputs_macros.html.twig' as inputs %}

<form name="form" method="post" action="{{ action }}">
    {{ inputs.hidden('_glpi_csrf_token', csrf_token()) }}
    {% if not is_new %}{{ inputs.hidden('id', item_id) }}{% endif %}

    <div class="card mt-2">
        <div class="card-body">

            <div class="row mb-3">
                <label class="col-4 col-form-label">
                    {{ __('Designation', 'metademands') }}
                    <span class="text-danger">*</span>
                </label>
                <div class="col-8">
                    <input type="text" class="form-control" name="name" value="{{ name }}">
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-4 col-form-label">{{ __('Description') }}</label>
                <div class="col-8">
                    {% do call('Html::textarea', [{'name': 'description', 'value': description,
                        'enable_richtext': false, 'cols': 5, 'rows': 5}]) %}
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-4 col-form-label">
                    {{ __('Reference', 'metademands') }}
                    <span class="text-danger">*</span>
                </label>
                <div class="col-8">
                    <input type="text" class="form-control" name="reference" value="{{ reference }}">
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-4 col-form-label">
                    {{ type_name }}
                    <span class="text-danger">*</span>
                </label>
                <div class="col-8">
                    {{ type_dropdown_html|raw }}
                </div>
            </div>

        </div>
        <div class="card-footer d-flex justify-content-end gap-2">
            {% if is_new %}
                <button class="btn btn-primary" type="submit" name="add" value="1">
                    <i class="ti ti-device-floppy"></i>
                    <span>{{ _x('button', 'Add') }}</span>
                </button>
            {% else %}
                <button class="btn btn-primary" type="submit" name="update" value="1">
                    <i class="ti ti-device-floppy"></i>
                    <span>{{ _x('button', 'Save') }}</span>
                </button>
                <button class="btn btn-danger" type="submit" name="delete" value="1"
                        onclick="return confirm('{{ __('Are you sure you want to delete this item?')|e('js') }}');">
                    <i class="ti ti-trash"></i>
                    <span>{{ _x('button', 'Delete permanently'), }}</span>
                </button>
            {% endif %}
        </div>
    </div>
</form>
