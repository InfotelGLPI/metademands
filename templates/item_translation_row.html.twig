{% set lang = translation.fields['language'] %}
{% set lang_name = call('Dropdown::getLanguageName', [lang]) %}

{# ── Build datatable entries for the modal ──────────────────────────── #}
{% set modal_entries = [] %}
{% for handlers in metademand.listTranslationsHandlers() %}
    {% set group_rows = [] %}
    {% for handler in handlers %}
        {% set item_translation = translation.getForItemKeyAndLanguage(
            handler.getItem(),
            handler.getKey(),
            lang
        ) %}
        {% if handler.getValue() is not empty
            or (item_translation is not null and item_translation.getTranslation() is not empty) %}

            {% set default_value = handler.isRichText()
                ? handler.getValue()|safe_html
                : handler.getValue()|e %}
            {% if handler.getValue() is empty %}
                {% set default_value = '<span class="text-muted fst-italic">' ~ __('No default value') ~ '</span>' %}
            {% endif %}

            {% set group_rows = group_rows|merge([{
                'field'      : '<span class="fw-medium">' ~ handler.getName() ~ '</span>',
                'default'    : default_value,
                'translation': _self.getTranslationInput(handler, item_translation, lang),
            }]) %}
        {% endif %}
    {% endfor %}

    {% if group_rows is not empty %}
        {% set category = handlers|first.getCategory() %}
        {% if category %}
            {% set modal_entries = modal_entries|merge([{
                'field'        : '<span class="text-muted fw-semibold small">' ~ category ~ '</span>',
                'field_colspan': 3,
            }]) %}
        {% endif %}
        {% set modal_entries = modal_entries|merge(group_rows) %}
    {% endif %}
{% endfor %}

{# ── Language link (shown in datatable cell) ─────────────────────────── #}
<button type="button"
        class="btn btn-link p-0"
        data-bs-toggle="modal"
        data-bs-target="#metademand-tr-modal-{{ lang }}"
        aria-label="{{ __('Edit translation') }}">
    <strong>{{ lang_name }}</strong>
</button>

{# ── Edit modal ──────────────────────────────────────────────────────── #}
<div class="modal fade"
     id="metademand-tr-modal-{{ lang }}"
     tabindex="-1"
     role="dialog"
     aria-labelledby="metademand-tr-modal-title-{{ lang }}">
    <div class="modal-dialog modal-xl modal-dialog-scrollable" role="document">
        <form class="modal-content" method="POST" action="{{ ajax_url }}">
            <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}"/>
            <input type="hidden" name="action" value="save_translations"/>
            <input type="hidden" name="translation_class" value="{{ translation_class }}"/>
            <input type="hidden" name="meta_translation_id" value="{{ translation.getID() }}"/>

            <div class="modal-header border-bottom-0">
                <h5 class="modal-title" id="metademand-tr-modal-title-{{ lang }}">
                    {{ __('Translations: %s')|format(lang_name) }}
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ __('Close') }}"></button>
            </div>

            <div class="modal-body p-0">
                {% include "components/datatable.html.twig" with {
                    'datatable_id': 'metademand-tr-datatable-' ~ lang,
                    'columns': {
                        'field'      : __('Field'),
                        'default'    : __('Default (%s)')|format(call('Dropdown::getLanguageName', [config('language')])),
                        'translation': lang_name,
                    },
                    'formatters': {
                        'field'      : 'raw_html',
                        'default'    : 'raw_html',
                        'translation': 'raw_html',
                    },
                    'entries'     : modal_entries,
                    'total_number': 1,
                    'nofilter'    : true,
                    'nosort'      : true,
                } only %}
            </div>

            <div class="modal-footer border-top-0">
                {% if canedit %}
                    <div class="d-flex flex-row-reverse w-100">
                        <button class="btn btn-primary ms-2" type="submit" name="save"
                                aria-label="{{ __('Save translation') }}">
                            <i class="ti ti-device-floppy me-2"></i>{{ __('Save') }}
                        </button>
                        <button class="btn btn-ghost-danger" type="submit" name="delete"
                                form="metademand-tr-delete-{{ lang }}"
                                aria-label="{{ __('Delete translation') }}">
                            <i class="ti ti-trash me-2"></i>{{ _x('button', 'Delete permanently') }}
                        </button>
                    </div>
                {% else %}
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        <i class="ti ti-x me-2"></i>{{ __('Close') }}
                    </button>
                {% endif %}
            </div>
        </form>

        {% if canedit %}
            <form id="metademand-tr-delete-{{ lang }}"
                  method="POST" action="{{ ajax_url }}" hidden>
                <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}"/>
                <input type="hidden" name="action" value="delete_language"/>
                <input type="hidden" name="translation_class" value="{{ translation_class }}"/>
                <input type="hidden" name="items_id" value="{{ metademand.getID() }}"/>
                <input type="hidden" name="itemtype" value="{{ metademand.getType() }}"/>
                <input type="hidden" name="language" value="{{ lang }}"/>
            </form>
        {% endif %}
    </div>
</div>

{% macro getTranslationInput(handler, translation, language) %}
    {% set rand = random() %}
    <input type="hidden" name="translations[{{ rand }}][itemtype]" value="{{ get_class(handler.getItem()) }}"/>
    <input type="hidden" name="translations[{{ rand }}][items_id]" value="{{ handler.getItem().getID() }}"/>
    <input type="hidden" name="translations[{{ rand }}][key]" value="{{ handler.getKey() }}"/>
    <input type="hidden" name="translations[{{ rand }}][language]" value="{{ language }}"/>

    <div class="d-flex align-items-center">
        {% if translation and translation.isPossiblyObsolete() %}
            <i class="ti ti-alert-circle text-warning me-1"
               data-bs-toggle="tooltip"
               title="{{ __('The default value has changed since the last translation') }}"></i>
        {% endif %}

        {% set current_value = '' %}
        {% if translation %}{% set current_value = translation.getTranslation() %}{% endif %}

        {% if handler.isRichText() %}
            <textarea name="translations[{{ rand }}][translations][one]"
                      class="form-control" rows="3"
                      placeholder="{{ __('Enter translation') }}">{{ current_value|e }}</textarea>
        {% else %}
            <input type="text"
                   name="translations[{{ rand }}][translations][one]"
                   class="form-control"
                   value="{{ current_value|e }}"
                   placeholder="{{ __('Enter translation') }}"/>
        {% endif %}
    </div>
{% endmacro %}
