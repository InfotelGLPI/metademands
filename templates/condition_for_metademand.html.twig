{% import 'components/form/basic_inputs_macros.html.twig' as inputs %}

{# Formulaire 1 : règle d'affichage du bouton Soumettre #}
<form name="form_rule" method="post" action="{{ rule_action }}">
    {{ inputs.hidden('_glpi_csrf_token', csrf_token()) }}
    {{ inputs.hidden('id', metademand_id) }}

    <div class="card mt-2">
        <div class="card-header">
            <h3 class="card-title">{{ __('Rule', 'metademands') }}</h3>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <label class="col-4 col-form-label">
                    {{ __('Submit button display', 'metademands') }}
                </label>
                <div class="col-8">
                    {{ show_rule_html|raw }}
                </div>
            </div>
        </div>
        <div class="card-footer d-flex justify-content-end">
            <button class="btn btn-primary" type="submit" name="apply_rule" value="1">
                <i class="ti ti-check"></i>
                <span>{{ _x('button', 'Apply') }}</span>
            </button>
        </div>
    </div>
</form>

{# Formulaire 2 : ajout d'une condition (uniquement si la règle n'est pas "Toujours affiché") #}
{% if show_rule != show_rule_always %}
<form name="form_condition" method="post" action="{{ condition_action }}">
    {{ inputs.hidden('_glpi_csrf_token', csrf_token()) }}
    {{ inputs.hidden('plugin_metademands_metademands_id', metademand_id) }}

    <div class="card mt-3">
        <div class="card-body">
            <div class="row g-2 align-items-start mb-2">
                <div class="col fw-bold">{{ __('Logical operator', 'metademands') }}</div>
                <div class="col fw-bold">
                    {{ __('Field', 'metademands') }}
                    <span class="text-danger">*</span>
                </div>
                <div class="col fw-bold">{{ __('Field type', 'metademands') }}</div>
                <div class="col fw-bold">
                    {{ __('Equality operator', 'metademands') }}
                    <span class="text-danger">*</span>
                </div>
                <div class="col fw-bold">{{ __('Value to check', 'metademands') }}</div>
                <div class="col fw-bold">
                    {{ __('Pool', 'metademands') }}
                    <span class="text-danger">*</span>
                    <small class="text-primary d-block">
                        {{ __('Order of execution and grouping of conditions', 'metademands') }}
                    </small>
                </div>
                <div class="col"></div>
            </div>

            <div class="row g-2 align-items-center">
                <div class="col">
                    {{ show_logic_html|raw }}
                </div>
                <div class="col">
                    {{ fields_dropdown_html|raw }}
                    {% do call('Ajax::updateItemOnSelectEvent', [
                        'dropdown_plugin_metademands_fields_id' ~ rand,
                        'show_type_field' ~ rand,
                        plugin_web_dir ~ '/ajax/show_type_field.php',
                        {'fields_id': '__VALUE__', 'rand': rand}
                    ]) %}
                    {% do call('Ajax::updateItemOnSelectEvent', [
                        'dropdown_plugin_metademands_fields_id' ~ rand,
                        'show_dropdown_condition_' ~ rand,
                        plugin_web_dir ~ '/ajax/show_conditions.php',
                        {'fields_id': '__VALUE__', 'rand': rand}
                    ]) %}
                    {% do call('Ajax::updateItemOnSelectEvent', [
                        'dropdown_plugin_metademands_fields_id' ~ rand,
                        'show_value_to_check_' ~ rand,
                        plugin_web_dir ~ '/ajax/show_check_value.php',
                        {'fields_id': '__VALUE__', 'rand': rand}
                    ]) %}
                </div>
                <div class="col">
                    <span id="show_type_field{{ rand }}"></span>
                </div>
                <div class="col">
                    <span id="show_dropdown_condition_{{ rand }}"></span>
                </div>
                <div class="col">
                    <span id="show_value_to_check_{{ rand }}"></span>
                </div>
                <div class="col">
                    {{ order_dropdown_html|raw }}
                </div>
                <div class="col">
                    <button class="btn btn-primary" type="submit" name="add" value="1">
                        <i class="ti ti-plus"></i>
                        <span>{{ _x('button', 'Add') }}</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>
{% endif %}
